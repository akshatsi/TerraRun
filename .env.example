# ──────────────────────────────────────────────
# TerraRun — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# PostgreSQL / PostGIS
POSTGRES_USER=terrarun
POSTGRES_PASSWORD=terrarun_secret
POSTGRES_DB=terrarun
DATABASE_URL=postgresql+asyncpg://terrarun:terrarun_secret@db:5432/terrarun

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=TerraRun
DEBUG=true
