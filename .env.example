# ──────────────────────────────────────────────
# INTVL — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# PostgreSQL / PostGIS
POSTGRES_USER=intvl
POSTGRES_PASSWORD=intvl_secret
POSTGRES_DB=intvl
DATABASE_URL=postgresql+asyncpg://intvl:intvl_secret@db:5432/intvl

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=INTVL
DEBUG=true
